# Normalize line endings so cross-platform checkouts (WSL/Linux <-> Windows)
# stop producing whole-file CRLF/LF diffs with no real content change.
* text=auto eol=lf

# Windows scripts genuinely want CRLF.
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary types — never touch line endings.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.jar binary
*.keystore binary
*.jks binary
